{
    "version": "0.2.0",
    "python.analysis.extraPaths": [
        "${workspaceRoot}",
        "${workspaceFolder}"
    ],
    "configurations": [
        {
            "name": "Python: Current File (Integrated Terminal)",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceRoot}",
            "env": {"PYTHONPATH": "${workspaceRoot};${workspaceFolder}"}
        }
    ]
}
