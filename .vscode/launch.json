{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "preLaunchTask": "echoWorkspaceFolder"
        }
    ],
    "tasks": [
        {
          "label": "echoWorkspaceFolder",
          "type": "shell",
          "command": "echo",
          "args": ["${workspaceFolder}"],
          "group": {
            "kind": "build",
            "isDefault": true
          }
        }
      ]
}

